<?xml version="1.0" encoding="utf-8"?>
<!-- 适老单页:全屏精灵 + 一个超大"按住说话"按钮。高对比、超大字、零层级。 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <TextView
        android:id="@+id/spirit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧞"
        android:textSize="120sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/hint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/wake_hint"
        android:textColor="#9AA7B4"
        android:textSize="26sp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toTopOf="@id/btnTalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 超大点击区:老人手抖也能按到 -->
    <Button
        android:id="@+id/btnTalk"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="64dp"
        android:text="@string/press_to_talk"
        android:textSize="34sp"
        android:textColor="#04110F"
        android:backgroundTint="#3FB6A8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
